{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-conf-schema/main/schema.json",
  "productName": "VisionPipe",
  "version": "0.2.1",
  "identifier": "com.visionpipe.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VisionPipe",
        "width": 920,
        "height": 460,
        "resizable": true,
        "visible": false,
        "decorations": false,
        "transparent": true
      }
    ],
    "trayIcon": {
      "iconPath": "icons/32x32.png",
      "iconAsTemplate": false
    },
    "security": {
      "csp": null
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.icns",
      "icons/icon.png"
    ],
    "macOS": {
      "providerShortName": "M7GJV3YJ26",
      "entitlements": "entitlements.plist",
      "hardenedRuntime": true,
      "minimumSystemVersion": "10.13"
    }
  }
}
